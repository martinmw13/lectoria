  "info": {
    "description": "Multimodal EPUB reader with AI-driven narrative enrichment",
    "title": "Lectoria",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/books/": {
      "get": {
        "description": "List all books that have been uploaded.",
        "operationId": "list_books_api_books__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "items": {
                      "$ref": "#/components/schemas/BookSummary"
                    },
                    "type": "array"
                  },
                  "title": "Response List Books Api Books  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Books",
        "tags": [
          "books"
        ]
      }
    },
    "/api/books/upload": {
      "post": {
        "description": "Upload an EPUB and get a cost estimate before processing.\n\nThe EPUB is saved and ingested. Returns chapter/paragraph counts\nand a token estimate so the user can decide whether to proceed.",
        "operationId": "upload_and_estimate_api_books_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_and_estimate_api_books_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CostEstimate"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Upload And Estimate",
        "tags": [
          "books"
        ]
      }
    },
    "/api/books/{book_id}": {
      "get": {
        "description": "Get book metadata and NCM status.",
        "operationId": "get_book_api_books__book_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "book_id",
            "required": true,
            "schema": {
              "title": "Book Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookResponse"
                }
